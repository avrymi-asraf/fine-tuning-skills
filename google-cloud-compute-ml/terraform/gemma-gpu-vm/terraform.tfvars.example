# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your values

project_id = "my-gemma-project"
region     = "us-central1"
zone       = "us-central1-a"

instance_name = "gemma-trainer"
machine_type  = "n1-standard-4"
gpu_type      = "nvidia-tesla-t4"
gpu_count     = 1

# Use spot instances for 60-90% cost savings
# Warning: Spot VMs can be preempted
use_spot = false

# Boot disk size (GB)
boot_disk_size = 100

# Create a GCS bucket for data storage
create_gcs_bucket = true
